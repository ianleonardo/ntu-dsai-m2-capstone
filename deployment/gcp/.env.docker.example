# .env configuration for Dagster Docker Compose instance
# Copy this file to .env and fill in the actual values

# ---------------------------------------------
# Google Cloud Configuration
# ---------------------------------------------
GOOGLE_PROJECT_ID=ntu-dsai-488112
BIGQUERY_DATASET=insider_transactions

# Absolute path on your VM to your service account key.
# Inside the container, this automatically maps to /app/gcp-credentials.json
# Ensure this file exists on the host VM!
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# ---------------------------------------------
# Dagster PostgreSQL Configurations
# ---------------------------------------------
# Keep these synced with the docker-compose.yml database definitions
DAGSTER_POSTGRES_HOST=postgres
DAGSTER_POSTGRES_USER=dagster
DAGSTER_POSTGRES_PASSWORD=dagster_password_secure
DAGSTER_POSTGRES_DB=dagster
DAGSTER_POSTGRES_PORT=5432
