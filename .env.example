# Google Cloud Project ID
GOOGLE_PROJECT_ID=ntu-dsai-488112

# Google Cloud Storage bucket name (optional, defaults to dsai-m2-bucket)
GCS_BUCKET_NAME=dsai-m2-bucket

# Google Application Credentials (optional - if using service account key)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# --- Meltano: GCS → BigQuery SEC insider load ---
# BigQuery: path to GCP service account JSON (needs BigQuery Data Editor + Job User, Storage Object Viewer for GCS)
# TARGET_BIGQUERY_CREDENTIALS_PATH=/path/to/gcp-service-account-key.json
# GCS sync + BigQuery both use GOOGLE_APPLICATION_CREDENTIALS if set, or Application Default Credentials.
# Optional overrides for sync script (defaults shown):
# SEC_LOAD_YEAR=2025
# SEC_LOAD_QUARTER=q1  # optional: q1,q2,q3,q4; omit for all quarters
# GCS_BUCKET=dsai-m2-bucket
# GCS_SEC_PREFIX=sec-data
# STAGING_DIR=staging
