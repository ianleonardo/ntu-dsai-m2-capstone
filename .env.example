# Centralized SEC Pipeline Configuration
# This file provides a single source of truth for all pipeline parameters

# Core Pipeline Parameters (control all assets)
SEC_YEAR=2024
BIGQUERY_DATASET=insider_transactions
SEC_LOAD_QUARTER=
SEC_BATCH_SIZE=10000

# BigQuery Configuration
GOOGLE_PROJECT_ID=ntu-dsai

# Google Application Credentials (optional - if using service account key)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Processing Options
DRY_RUN=false
